{
  "name": "meteor-docs",
  "version": "0.0.5",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:changelog": "node scripts/sync-changelogs.mjs",
    "predev": "pnpm sync:changelog",
    "dev": "nuxt dev --port 3001 --open",
    "prebuild": "pnpm sync:changelog",
    "build": "nuxt build",
    "pregenerate": "pnpm sync:changelog",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && pnpm sync:changelog",
    "lint:all": "pnpm lint:types && pnpm format:check",
    "format:check": "prettier . --check",
    "lint:types": "nuxt typecheck && tsc --noEmit -p test/tsconfig.json",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@shopware-ag/meteor-component-library": "workspace:*",
    "@shopware-ag/meteor-icon-kit": "workspace:*",
    "@shopware-ag/meteor-tokens": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "docus": "^5.12.1",
    "nuxt": "^4.3.1",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^3.19.2",
    "nuxt-component-meta": "^0.17.2",
    "prettier": "^3.5.3",
    "typescript": "~5.7.3",
    "vitest": "^3.2.0",
    "vue-tsc": "^2.2.0"
  }
}
